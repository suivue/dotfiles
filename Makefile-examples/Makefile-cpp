# target: dependencies
# 	action
CXX=g++
CXXFLAGS=-Wall -std=c++14 -I$(INC_DIR)
SRC_DIR := src
INC_DIR := $(SRC_DIR)/include
BUILD_DIR := build
EXT = cpp
HEXT = h
SOURCES = $(wildcard $(SRC_DIR)/*.$(EXT))
INCLUDES = $(wildcard $(INC_DIR)/*.$(HEXT))
OBJECTS = $(patsubst $(SRC_DIR)/%.$(EXT),$(BUILD_DIR)/%.o,$(SOURCES))
TARGET = $(notdir $(CURDIR))

all: $(BUILD_DIR) $(TARGET)

$(TARGET): $(OBJECTS)
	$(CXX) $^ -o $@

$(BUILD_DIR)/%.o: $(SRC_DIR)/%.$(EXT)
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Create the build directory if it does not exist. Apparently this is requried.
$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

clean:
	rm -f $(OBJECTS) $(TARGET)

.PHONY: all clean

